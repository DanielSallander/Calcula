{
  "name": "calcula",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:data": "cross-env VITE_LOAD_MOCK_DATA=true vite",
    "build": "tsc --noEmit -p tsconfig.check.json && vite build",
    "check-types": "tsc --noEmit -p tsconfig.check.json",
    "check-types:watch": "tsc --noEmit -p tsconfig.check.json --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev:data": "cross-env VITE_LOAD_MOCK_DATA=true tauri dev",
    "e2e": "playwright test --project=functional",
    "e2e:visual": "playwright test --project=visual",
    "e2e:all": "playwright test",
    "e2e:manual": "cross-env E2E_MANUAL=1 playwright test --project=functional",
    "e2e:manual:all": "cross-env E2E_MANUAL=1 playwright test",
    "e2e:visual:update": "playwright test --project=visual --update-snapshots",
    "e2e:visual:baseline": "playwright test --project=visual --update-snapshots && node ../tests/regression/validate-baselines.mjs",
    "e2e:visual:baseline:auto": "playwright test --project=visual --update-snapshots && node ../tests/regression/validate-baselines.mjs --auto-fix",
    "e2e:visual:review": "node ../tests/regression/validate-baselines.mjs",
    "e2e:invariant": "playwright test --project=invariant",
    "e2e:invariant:manual": "cross-env E2E_MANUAL=1 playwright test --project=invariant",
    "e2e:report": "playwright show-report",
    "regression": "node ../tests/regression/regression-runner.mjs",
    "regression:auto": "node ../tests/regression/regression-runner.mjs --mode=auto --max-iterations=15",
    "regression:auto:fix-app": "node ../tests/regression/regression-runner.mjs --mode=auto --max-iterations=15 --allow-app-fixes",
    "regression:manual": "node ../tests/regression/regression-runner.mjs --e2e-manual",
    "regression:manual:auto": "node ../tests/regression/regression-runner.mjs --mode=auto --max-iterations=15 --e2e-manual"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-log": "~2",
    "jspdf": "^4.2.1",
    "monaco-editor": "^0.55.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styled-components": "^6.3.8",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^25.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/styled-components": "^5.1.36",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-boundaries": "^5.3.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "jsdom": "^29.0.0",
    "madge": "^8.0.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.54.0",
    "vite": "^6.0.1",
    "vitest": "^4.1.0"
  }
}
